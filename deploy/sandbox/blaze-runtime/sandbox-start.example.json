{
  "project": "art",
  "spec": {
    "flavor": "2cpu-4ram",
    "image": "docker-hosted.artifactory.tcsbank.ru/art/blaze-runtime-sandbox:<tag>",
    "containerPorts": [
      {
        "name": "http",
        "port": 4170
      }
    ],
    "environment": {
      "BLAZE_RUNTIME_TOKEN": "<runtime-bearer-token-generated-by-blaze>",
      "BLAZE_DP_TOKEN": "<dp-token-for-nestor-exchange>",
      "BLAZE_RUNTIME_HOST": "0.0.0.0",
      "BLAZE_RUNTIME_PORT": "4170",
      "BLAZE_RUNTIME_WORKSPACE": "/workspace"
    }
  },
  "startupOptions": {
    "executeCommand": [
      "/entrypoint.sh"
    ],
    "terminateAfterCommand": false
  }
}
