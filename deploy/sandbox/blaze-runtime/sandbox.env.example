# Copy this file into the sandbox start configuration. Do not commit real
# values. The sandbox API may express these as a map rather than an env file.

# Required. Generated by Nessy Blaze/BFF per user/project runtime session.
BLAZE_RUNTIME_TOKEN=<runtime-bearer-token>

# Required for the DP/Nestor exchange path. You can pass either BLAZE_DP_TOKEN
# directly or legacy DP_TOKEN; entrypoint.sh maps DP_TOKEN -> BLAZE_DP_TOKEN.
BLAZE_DP_TOKEN=<dp-token>
# DP_TOKEN=<dp-token>

# Alternative delegated JWT path. Use only if the platform already gives the
# runtime a delegated Nestor/Spirit JWT.
# BLAZE_DP_JWT=<delegated-jwt>
# NESSY_CLI_DP_AUTH_TOKEN=<delegated-jwt>

# Runtime listener inside the sandbox.
BLAZE_RUNTIME_HOST=0.0.0.0
BLAZE_RUNTIME_PORT=4170
BLAZE_RUNTIME_WORKSPACE=/workspace

# Optional Nestor overrides. Leave unset for the default MVP path.
# BLAZE_NESTOR_MODEL=tgpt/qwen3-next-80b-a3b-instruct
# BLAZE_NESTOR_SERVER_URL=https://code-completion-nestor.tcsbank.ru
# BLAZE_NESTOR_BASE_URL=https://code-completion-nestor.tcsbank.ru/api/v1/cli/openai-like/v1
